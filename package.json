    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.0",
    "obsidian": "latest",
    "tslib": "2.6.0",
    "typescript": "5.4.5"
  },
  "dependencies": {
    "marked": "^12.0.0"
  }
}
